  "concepts": [
    {
      "id": "c.mouse",
      "kind": "atomic",
      "status": "stable",
      "prefLabel": "computer mouse",
      "altLabels": ["mouse"],
      "definitions": [
        {
          "scope": "root",
          "axisId": null,
          "parentId": null,
          "delimitingCharacteristicIds": [],
          "text": "hand-manipulated device used to control a cursor on a computer display"
        }
      ],
      "notes": {
        "scope": "Includes all pointing devices commonly called 'mouse' regardless of tracking or connection mechanism",
        "history": "Term originates from physical resemblance to the animal; first used at Stanford Research Institute in 1960s"
      }
    },
    {
      "id": "c.mouse.optical",
      "kind": "atomic",
      "status": "stable",
      "prefLabel": "optical mouse",
      "altLabels": [],
      "deprecatedLabels": ["LED mouse"],
      "definitions": [
        {
          "scope": "axis",
          "axisId": "axis.tracking",
          "parentId": "c.mouse",
          "delimitingCharacteristicIds": ["ch.tracking.light_sensors"],
          "text": "computer mouse with movement detected by light sensors"
        }
      ]
    },
    {
      "id": "c.mouse.mechanical",
      "kind": "atomic",
      "status": "stable",
      "prefLabel": "mechanical mouse",
      "altLabels": ["ball mouse"],
      "deprecatedLabels": [],
      "definitions": [
        {
          "scope": "axis",
          "axisId": "axis.tracking",
          "parentId": "c.mouse",
          "delimitingCharacteristicIds": ["ch.tracking.rolling_ball"],
          "text": "computer mouse with movement detected by a rolling ball"
        }
      ],
      "notes": {
        "history": "Dominant technology from 1970s-2000s; largely replaced by optical"
      }
    },
    {
      "id": "c.mouse.laser",
      "kind": "atomic",
      "status": "stable",
      "prefLabel": "laser mouse",
      "altLabels": [],
      "definitions": [
        {
          "scope": "axis",
          "axisId": "axis.tracking",
          "parentId": "c.mouse",
          "delimitingCharacteristicIds": ["ch.tracking.laser"],
          "text": "computer mouse with movement detected by laser sensors"
        }
      ],
      "notes": {
        "scope": "Distinguished from optical mouse by use of laser rather than LED; may work on more surface types"
      }
    },
    {
      "id": "c.mouse.wireless",
      "kind": "atomic",
      "status": "stable",
      "prefLabel": "wireless mouse",
      "altLabels": ["cordless mouse"],
      "deprecatedLabels": [],
      "definitions": [
        {
          "scope": "axis",
          "axisId": "axis.connection",
          "parentId": "c.mouse",
          "delimitingCharacteristicIds": ["ch.connection.no_cable"],
          "text": "computer mouse that connects without a physical cable"
        }
      ],
      "notes": {
        "scope": "Includes Bluetooth, RF, and infrared connections"
      }
    },
    {
      "id": "c.mouse.wired",
      "kind": "atomic",
      "status": "stable",
      "prefLabel": "wired mouse",
      "altLabels": ["corded mouse"],
      "deprecatedLabels": [],
      "definitions": [
        {
          "scope": "axis",
          "axisId": "axis.connection",
          "parentId": "c.mouse",
          "delimitingCharacteristicIds": ["ch.connection.cable"],
          "text": "computer mouse that connects via physical cable"
        }
      ],
      "notes": {
        "scope": "Includes USB, PS/2, and serial connections"
      }
    },
    {
      "id": "c.mouse.trackball",
      "kind": "atomic",
      "status": "stable",
      "prefLabel": "trackball mouse",
      "altLabels": ["trackball"],
      "definitions": [
        {
          "scope": "axis",
          "axisId": "axis.form_factor",
          "parentId": "c.mouse",
          "delimitingCharacteristicIds": ["ch.form.stationary_ball"],
          "text": "computer mouse where a ball is manipulated by fingers while the body remains stationary"
        }
      ]
    },
    {
      "id": "c.mouse.ergonomic",
      "kind": "atomic",
      "status": "provisional",
      "prefLabel": "ergonomic mouse",
      "altLabels": ["vertical mouse"],
      "definitions": [
        {
          "scope": "axis",
          "axisId": "axis.form_factor",
          "parentId": "c.mouse",
          "delimitingCharacteristicIds": ["ch.form.vertical_grip"],
          "text": "computer mouse with vertical grip orientation reducing wrist pronation"
        }
      ],
      "notes": {
        "editorial": "Status provisional pending confirmation that vertical grip is the essential characteristic vs other ergonomic features"
      }
    },
    {
      "id": "c.cursor",
      "kind": "atomic",
      "status": "stable",
      "prefLabel": "cursor",
      "altLabels": ["pointer"],
      "definitions": [
        {
          "scope": "root",
          "axisId": null,
          "parentId": null,
          "delimitingCharacteristicIds": [],
          "text": "visual indicator on a display showing the current position for user input"
        }
      ]
    },
    {
      "id": "c.mouse.wireless_optical",
      "kind": "compound",
      "status": "stable",
      "prefLabel": "wireless optical mouse",
      "altLabels": [],
      "components": [
        { "axisId": "axis.tracking", "conceptId": "c.mouse.optical" },
        { "axisId": "axis.connection", "conceptId": "c.mouse.wireless" }
      ],
      "definitions": [
        {
          "scope": "multi",
          "parentId": "c.mouse",
          "delimitingCharacteristicIds": ["ch.tracking.light_sensors", "ch.connection.no_cable"],
          "text": "computer mouse with movement detected by light sensors that connects without a physical cable"
        }
      ],
      "notes": {
        "scope": "Materialized as compound because this is the most common product category in current inventory"
      }
    }
